---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "tony@ouma:~$",
  description = "Software engineer. I build clean, reliable products.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content="Tony Ouma" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://tonyouma.com" />
    <meta property="og:site_name" content="Tony Ouma" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Tony Ouma" />
    <meta name="twitter:description" content={description} />

  </head>
  <body>
    <slot />
  </body>
</html>
